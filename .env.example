# ----------------------------------------------------------------------
# LLM Benchmark Kit — 环境变量示例
# ----------------------------------------------------------------------
# 用法:
#   cp .env.example .env
#   根据实际情况填写，并用 `source .env` 或 `export $(cat .env | xargs)` 加载
#
# 注意: .env 已被 .gitignore 屏蔽，切勿提交真实密钥。
# ----------------------------------------------------------------------

# API 网关地址 (OpenAI 兼容端点，去掉结尾斜杠)
LLM_API_BASE="https://api.example.com"

# API Key (Bearer Token)
LLM_API_KEY="sk-your-api-key-here"

# 默认要测试的模型 ID (多个用英文逗号分隔)
TARGET_MODELS="gpt-4o-mini"

# ---- 可选 ----

# 单请求超时时间 (秒)
LLM_HTTP_TIMEOUT="180"

# 压测线程池最大并发
LLM_MAX_WORKERS="8"

# 报告输出根目录 (相对项目根目录的路径；默认 reports)
LLM_REPORT_DIR="reports"
